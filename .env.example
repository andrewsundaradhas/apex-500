# Copy to .env and adjust. Never commit .env.

# --- Environment ---
# Set to "production" on public deployments. Enables fail-fast checks and
# disables the demo-user soft-auth fallback.
APEX_ENV=development

# --- Security ---
# REQUIRED in production. Minimum 32 chars of entropy.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
APEX_JWT_SECRET=change-me-to-a-long-random-string
APEX_JWT_TTL_MIN=1440
APEX_BCRYPT_ROUNDS=12

# --- Demo user ---
# Seeded only in development by default. In production set APEX_DEMO_USER=1
# AND APEX_DEMO_PASSWORD=<something> to deliberately ship a demo account.
# APEX_DEMO_USER=0
# APEX_DEMO_PASSWORD=

# --- CORS ---
# Comma-separated list of origins allowed to hit the API. Use * only for local dev.
APEX_CORS_ORIGINS=*

# --- Data providers ---
# Finnhub for reliable market data (recommended for production).
# Create a free key and set it in your *runtime environment* (Fly secrets, local .env).
APEX_FINNHUB_KEY=

# FRED macro data API key (optional). If omitted, backend uses public CSV endpoint.
APEX_FRED_API_KEY=

# --- Rate limiting ---
# slowapi format: <count>/<period>, e.g. 120/minute, 2000/hour
APEX_RATE_LIMIT=120/minute

# --- Cache TTLs (seconds) ---
APEX_PREDICT_TTL=900
APEX_HISTORY_TTL=300

# --- WebSocket tuning ---
APEX_WS_POLL=15
APEX_WS_TICK=1.0

# --- Frontend ---
VITE_API_URL=http://localhost:8000

# --- Email delivery (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@yourdomain.com
